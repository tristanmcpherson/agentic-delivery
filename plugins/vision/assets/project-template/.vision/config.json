{
  "schema_version": 2,
  "authority": {
    "mode": "local"
  },
  "evidence_root": ".vision/evidence",
  "defaults": {
    "check_timeout_ms": 900000,
    "max_log_bytes": 5000000
  },
  "orchestration": {
    "max_scouts": 3,
    "max_parallel_nodes": 3,
    "max_review_retries": 2,
    "max_no_progress_resumes": 2,
    "max_authorization_failures": 3,
    "max_context_percent": 80,
    "allow_recursive_subagents": false,
    "telemetry": false,
    "auto_update": false,
    "auto_merge": false,
    "worktrees": {
      "mode": "optional",
      "require_task_ownership": true
    },
    "hooks": {
      "enabled": true,
      "authority": "advisory",
      "network": "disabled",
      "offer_vision_on_engineering_outcome": true
    },
    "reviews": {
      "authority": "builder-side-advisory",
      "inconclusive": "fail",
      "current_attempt_only": true
    }
  },
  "quality": {
    "fail_on_console_errors": true,
    "fail_on_page_errors": true,
    "fail_on_failed_requests": true,
    "ignore_console_patterns": [],
    "ignore_request_patterns": []
  },
  "profiles": {
    "mocked-ui": {
      "enabled": false,
      "kind": "mocked",
      "app_origin": "http://127.0.0.1:3000",
      "api_origin": "http://127.0.0.1:3001",
      "mock_policy": "allow-first-party",
      "data_mode": "fixtures",
      "auth_mode": "test"
    },
    "local-real": {
      "enabled": false,
      "kind": "local-real",
      "app_origin": "http://127.0.0.1:3000",
      "api_origin": "http://127.0.0.1:3001",
      "mock_policy": "forbid-first-party",
      "data_mode": "seeded-local",
      "auth_mode": "test",
      "marker": {
        "header": "x-agentic-environment",
        "value": "local"
      },
      "probes": []
    },
    "shared-real": {
      "enabled": false,
      "kind": "mixed",
      "app_origin": "http://127.0.0.1:3000",
      "api_origin": "${DEV_API_ORIGIN}",
      "mock_policy": "forbid-first-party",
      "data_mode": "shared-dev-seed",
      "auth_mode": "test-user",
      "marker": {
        "header": "x-agentic-environment",
        "value": "development"
      },
      "required_env": ["DEV_API_ORIGIN"],
      "probes": []
    },
    "staging": {
      "enabled": false,
      "kind": "staging",
      "app_origin": "${STAGING_APP_ORIGIN}",
      "api_origin": "${STAGING_API_ORIGIN}",
      "mock_policy": "forbid-first-party",
      "data_mode": "staging-seed",
      "auth_mode": "staging-test-user",
      "external": true,
      "requires_approval": true,
      "required_env": ["STAGING_APP_ORIGIN", "STAGING_API_ORIGIN"],
      "marker": {
        "header": "x-agentic-environment",
        "value": "staging"
      },
      "probes": []
    },
    "production-smoke": {
      "enabled": false,
      "kind": "production",
      "app_origin": "${PRODUCTION_APP_ORIGIN}",
      "api_origin": "${PRODUCTION_API_ORIGIN}",
      "mock_policy": "forbid-first-party",
      "data_mode": "synthetic-safe",
      "auth_mode": "production-smoke-user",
      "external": true,
      "requires_approval": true,
      "required_env": ["PRODUCTION_APP_ORIGIN", "PRODUCTION_API_ORIGIN"],
      "marker": {
        "header": "x-agentic-environment",
        "value": "production"
      },
      "probes": []
    }
  }
}
