{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/agentic-lifecycle.mjs\" hook",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\agentic-lifecycle.mjs\" hook",
            "timeout": 10,
            "statusMessage": "Loading Vision context"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/agentic-lifecycle.mjs\" hook",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\agentic-lifecycle.mjs\" hook",
            "timeout": 10,
            "statusMessage": "Restoring Vision context"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "agentic-.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/agentic-lifecycle.mjs\" hook",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\agentic-lifecycle.mjs\" hook",
            "timeout": 10,
            "statusMessage": "Applying Vision role boundary"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/agentic-lifecycle.mjs\" hook",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\agentic-lifecycle.mjs\" hook",
            "timeout": 10,
            "statusMessage": "Checking Vision handoff state"
          }
        ]
      }
    ]
  }
}
